<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: grav.config.site.default_lang }}">
<head>
    {% block head %}
        <meta charset="utf-8" />
        <title>{% if header.title %}{{ header.title|e }} | {% endif %}{{ site.title|e }}</title>
        {% include 'partials/metadata.html.twig' %}
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/png" href="{{ url('theme://img/favicon.png') }}" />
        <link rel="alternate" type="application/rss+xml" title="{{ site.title|e }}" href="{{ base_url_absolute }}/blog.rss" />

        {# Inline critical CSS so the browser can paint above-the-fold content
           immediately without waiting for the external stylesheet #}
        <style>{{ source('partials/critical.css')|replace({"\n": " "}) }}</style>

        <link rel="preload" href="{{ url('theme://img/' ~ site.intro_avatar ) }}" as="image">
        <link rel="preload" href="{{ url('theme://img/regular.webp') }}" as="image" media="(max-width: 1280px)" fetchpriority="high">
        <link rel="preload" href="{{ url('theme://img/large.webp') }}" as="image" media="(min-width: 1281px)" fetchpriority="high">
        <link rel="preload" href="{{ url('theme://fonts/bunchlo.woff') }}" as="font" type="font/woff" crossorigin>
        <link rel="preload" href="{{ url('theme://fonts/fontawesome-webfont.woff?v=4.2.0') }}" as="font" type="font/woff" crossorigin>

        {% block javascripts %}
            {% do assets.addJs('jquery', {priority: 101}) %}
            {% do assets.addJs('theme://js/kube.min.js') %}
            {% do assets.addJs('theme://js/snap.svg-min.js') %}
        {% endblock %}

        {% block stylesheets %}
            {% do assets.addCss('theme://css/kube.min.css') %}
            {% do assets.addCss('theme://css/font-awesome.min.css') %}
            {% do assets.addCss('theme://css/custom.css') %}
        {% endblock %}

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Open+Sans:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
        <noscript><link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Open+Sans:wght@400;700&display=swap" rel="stylesheet"></noscript>

        {# SRI hashes for fonts.googleapis.com - not supported yet :( #}

        {# Load the full stylesheet async — critical CSS above covers first paint #}
        {% block assets deferred %}
            {% set css_link = assets.css() %}
            {{ css_link|replace({"rel=\"stylesheet\"": "rel=\"stylesheet\" media=\"print\" onload=\"this.media='all'\""})|raw }}
            <noscript>{{ css_link|raw }}</noscript>
            {{ assets.js()|replace({'<script src=': '<script defer="defer" src='})|raw }}
        {% endblock %}

    {% endblock head%}
</head>
<body class="{{ page.header.body_classes }}">

    <div class="main-nav">
        <div class="container">
            <header class="group top-nav">
                <nav class="navbar logo-w navbar-left" >
                    <a class="logo" href="{{ home_url }}">{{ site.title|e }}</a>
                </nav>
                <div class="navigation-toggle" data-tools="navigation-toggle" data-target="#navbar-1">
                    <span class="logo">{{ site.title|e }}</span>
                </div>
                {% include 'partials/navigation.html.twig' %}
            </header>
        </div>
    </div>

    <div class="intro">
        <div class="container">
            <div class="units-row">
                <div class="unit-10">
                    <img class="img-intro" src="{{ url('theme://img/' ~ site.intro_avatar ) }}" alt="" width="47" height="47" fetchpriority="high">
                </div>
                <div class="unit-90">
                    <p class="p-intro" lang="ga">{{ site.intro }}</p>
                </div>
            </div>
        </div>
    </div>

    {% block body %}
        <div class="content">
            <div class="container">
                {% block content %}{% endblock %}
            </div>
        </div>
    {% endblock %}

    <footer>
        <div class="container">
            <div class="units-row">
                <div class="unit-50">
                    <p class="text-centered foot-cp">
                        <a href="{{ site.author.url }}">{{ site.author.footer }}</a>
                    </p>
                </div>
                <div class="unit-50">
                    <ul class="social list-flat right">
                        {% for item in site.social %}
                            <li><a href="{{ item.link }}"><i class="fa fa-{{ item.icon }}"></i></a></li>
                        {% endfor %}
                    </ul>
                </div>
                <p class="text-centered foot-cp">
                    <a href="{{ site.author.url2}}">{{ site.author.footer2 }}</a>
                </p>
            </div>
        </div>
    </footer>

    {{ assets.js('bottom')|replace({'<script src=': '<script defer="defer" src='})|raw }}
</body>
</html>
