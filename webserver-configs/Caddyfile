# Snapshot of /etc/caddy/Caddyfile on the herculaneum droplet, captured
# 2026-04-09. NOT used at runtime by Caddy from this repo — production
# reads from /etc/caddy/Caddyfile + /etc/caddy/common.conf. Kept here
# for version control and disaster recovery only. To restore on a fresh
# host: copy this file to /etc/caddy/Caddyfile and the sibling
# webserver-configs/common.conf to /etc/caddy/common.conf, then
# `systemctl reload caddy`.
#
# This replaces the upstream Grav default Caddyfile (which was just
# `localhost` + `php_fastcgi 127.0.0.1:9000` and unused on this server).

{
	# Re-disable HTTP/3 advertising. We re-enabled it 2026-04-09 alongside
	# stripping the over-tuned tls block, but the actual QUIC handshake still
	# fails (ERR_QUIC_PROTOCOL_ERROR mid-handshake). Until that's diagnosed,
	# advertising alt-svc h3 just makes Chrome attempt QUIC and fall back
	# noisily — sometimes surfacing as ERR_HTTP2_PROTOCOL_ERROR. See
	# improvements.md #3 for the open investigation.
	servers {
		protocols h1 h2
	}
}

gregorykelleher.com {
	root * /var/www/gregorykelleher

	# Enable HTTP Strict Transport Security (HSTS) to force clients to always use https
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

	# Access logs (JSON, rotated at 10MB, keep last 5)
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 5
			mode 644
		}
		format json
	}

	php_fastcgi unix//run/php/php8.3-fpm.sock {
		read_timeout 60s
		write_timeout 60s
	}

	file_server

	# import common configurations
	import /etc/caddy/common.conf
}

www.gregorykelleher.com {
	redir https://gregorykelleher.com{uri} 301
}
